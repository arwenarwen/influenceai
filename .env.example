# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local:  postgresql://postgres:password@localhost:5432/influencehub
# Supabase: postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
# Neon:   postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/influencehub"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-min-32-chars-long-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── OpenAI (AI Matching & Discovery) ────────────────────────────────────────
# Create at: https://platform.openai.com/api-keys
# If not set, the platform will use rule-based matching (still works great!)
OPENAI_API_KEY="sk-proj-..."

# ─── Email (Notifications) ────────────────────────────────────────────────────
# SMTP settings for email notifications
# Gmail: Use App Password from https://myaccount.google.com/apppasswords
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="InfluenceHub <noreply@influencehub.io>"

# ─── Stripe (Payments) ────────────────────────────────────────────────────────
# Create at: https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Social Platform APIs (Optional — for real discovery) ─────────────────────
# TikTok Research API: https://developers.tiktok.com/products/research-api/
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# Instagram Graph API: https://developers.facebook.com/docs/instagram-api/
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""

# YouTube Data API v3: https://console.cloud.google.com/apis
YOUTUBE_API_KEY=""

# ─── AWS S3 (Portfolio Uploads) ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET="influencehub-uploads"

# ─── App Configuration ────────────────────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PLATFORM_FEE_PERCENTAGE="15"
